{
  "directory": [
    "./src/components",
    "./src/utils",
    "./src/utils-v2",
    "./src/shared",
    "./src/stores",
    "./src/modules-features",
    "./src/hooks",
    "./src/interfaces",
    "./src/core",
    "./src/types"
  ],
  "delete": true,
  "structure": "flat",
  "location": "top",
  "include": [
    ".ts",
    ".tsx"
  ],
  "exclude": [
    "__tests__",
    "__mocks__",
    ".*\\.test\\.ts$",
    ".*\\.test\\.tsx$",
    ".*\\.spec\\.ts$",
    ".*\\.spec\\.tsx$",
    "\\.stories\\.ts",
    "\\.stories\\.tsx"
  ],
  "singleQuotes": true,
  "noHeader": true,
  "semi": true,
  "mode": "modules"
}