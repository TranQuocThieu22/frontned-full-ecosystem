<?xml version="1.0" encoding="UTF-8"?>
<!--For alias-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>

        <rule name="Rewrite alias to lom" stopProcessing="true">
          <match url="^aliasexample/(.*)" />
          <action type="Rewrite" url="sae/{R:1}" />
        </rule>

        <rule name="SPA fallback" stopProcessing="true">
          <match url="^aliasexample/?$" />
          <action type="Rewrite" url="sae/index.html" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>



