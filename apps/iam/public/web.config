<?xml version="1.0" encoding="UTF-8"?>
<!--For alias-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Rewrite alias to srm" stopProcessing="true">
          <match url="^srm/(.*)" />
          <action type="Rewrite" url="srm/{R:1}" />
        </rule>
        <rule name="SPA fallback" stopProcessing="true">
          <match url="^srm/?$" />
          <action type="Rewrite" url="srm/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>

